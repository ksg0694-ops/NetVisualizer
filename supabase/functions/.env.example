# Free-only default: no external market data API is called.
MARKET_PRICE_PROVIDER=disabled

# Optional for scripts/kis-dry-run.ps1 against a deployed function.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key

# Optional free official Korean domestic quote provider.
# MARKET_PRICE_PROVIDER=kis
KIS_APP_KEY=replace_with_your_kis_app_key
KIS_APP_SECRET=replace_with_your_kis_app_secret
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Optional free-tier development test for US/global symbols only.
# Keep Korean exchange data blocked in code.
# MARKET_PRICE_PROVIDER=twelvedata
TWELVE_DATA_API_KEY=replace_with_free_twelve_data_key

# Optional: map local portfolio tickers to provider-specific symbols.
# Twelve Data supports exchange suffixes such as 005930:XKRX and 091990:XKOS.
TWELVE_DATA_SYMBOL_OVERRIDES={"005930":"005930:XKRX","091990":"091990:XKOS"}

# Free-only real estate subscription sync.
# Disabled by default: no Applyhome/data.go.kr API is called.
REALESTATE_SUBSCRIPTION_PROVIDER=disabled

# Optional free public-data provider for Korea Real Estate Board Applyhome data.
# Set REALESTATE_SUBSCRIPTION_PROVIDER=data-go-kr after the key is issued.
DATA_GO_KR_SERVICE_KEY=replace_with_data_go_kr_service_key
ODCLOUD_SERVICE_KEY=replace_with_odcloud_service_key
ODCLOUD_API_KEY=replace_with_optional_odcloud_authorization_key
APPLYHOME_API_BASE=https://api.odcloud.kr/api/ApplyhomeInfoDetailSvc/v1
